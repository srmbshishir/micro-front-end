{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "mfeHr/Module": ["./apps/mfe-hr/src/app/remote-entry/entry-module.ts"],
      "mfeFinance/Module": [
        "./apps/mfe-finance/src/app/remote-entry/entry-module.ts"
      ],
      "mfeHelpdesk/Module": [
        "./apps/mfe-helpdesk/src/app/remote-entry/entry-module.ts"
      ],
      "mfeAdmin/Module": [
        "./apps/mfe-admin/src/app/remote-entry/entry-module.ts"
      ],
      "@company-portal/shared-auth": ["./libs/shared/auth/src/index.ts"],
      "@company-portal/shared-data": ["./libs/shared/data/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
